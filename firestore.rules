rules_version = '2';

// CrypTalk Firestore security rules.
//
// Principles:
//   - The server stores only opaque ciphertext-bearing PNG URLs and
//     metadata. Salts are present (non-secret), passphrases are not.
//   - Conversation participants can read each other's conversation
//     metadata and messages. Outsiders see nothing.
//   - Every authenticated user can read the public users/{uid} doc to
//     resolve email → uid when starting a new conversation.

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isMe(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // --- /users/{uid} -----------------------------------------------------
    match /users/{uid} {
      // Anyone signed in can read user profiles (needed to look up by email).
      allow read: if isSignedIn();
      // Only the user themselves can create / overwrite their own doc.
      // Email & uid must match the auth token — prevents account spoofing.
      allow create: if isMe(uid)
                    && request.resource.data.email == request.auth.token.email
                    && request.resource.data.keys().hasAll(["email", "displayName", "createdAt"]);
      allow update: if isMe(uid)
                    && request.resource.data.email == resource.data.email;
      allow delete: if false;
    }

    // --- /conversations/{convoId} ----------------------------------------
    match /conversations/{convoId} {

      function isParticipant() {
        return isSignedIn() && request.auth.uid in resource.data.participants;
      }
      function willBeParticipant() {
        return isSignedIn() && request.auth.uid in request.resource.data.participants;
      }

      allow read: if isParticipant();

      // Anyone signed in can create a conversation as long as they're
      // listed as a participant. Both participants must be real uids.
      allow create: if willBeParticipant()
                    && request.resource.data.participants.size() == 2
                    && request.resource.data.participantEmails.size() == 2
                    && request.resource.data.salt is string
                    && request.resource.data.coverPoolIds is list;

      // Only participants can update; participant list is immutable.
      allow update: if isParticipant()
                    && request.resource.data.participants == resource.data.participants;

      allow delete: if false;

      // --- /conversations/{convoId}/messages/{msgId} ---------------------
      match /messages/{msgId} {

        function inConvo() {
          return isSignedIn() &&
                 request.auth.uid in get(/databases/$(database)/documents/conversations/$(convoId)).data.participants;
        }

        allow read: if inConvo();

        // Only a participant can create a message and only if they
        // identify themselves as the sender.
        allow create: if inConvo()
                      && request.resource.data.senderId == request.auth.uid
                      && request.resource.data.stegoUrl is string
                      && request.resource.data.coverId is string;

        // Messages are immutable once written.
        allow update, delete: if false;
      }
    }
  }
}
